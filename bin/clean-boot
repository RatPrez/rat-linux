#!/usr/bin/env bash
# clean-boot — quiet the boot for a clean look.
#
# Suppresses the scrolling kernel/systemd text, BUT keeps you informed on trouble:
#   quiet                     -> kernel prints only errors (KERN_ERR and worse)
#   systemd.show_status=auto  -> systemd unit status hidden, auto-shown on
#                                error or a slow/hanging unit
#   rd.udev.log_level=3       -> quieter udev in the initramfs
#   vt.global_cursor_default=0-> no blinking console cursor
# No Plymouth, no splash.
#
# Bootloader support: Limine only. Edits the kernel command line in limine's
# config file after backing it up. Idempotent — safe to re-run.
#
# Usage:
#   clean-boot            # apply
#   clean-boot --revert   # restore the most recent backup
set -euo pipefail

ADD="quiet systemd.show_status=auto rd.udev.log_level=3 vt.global_cursor_default=0"

log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m ok\033[0m %s\n' "$*"; }
die()  { printf '\033[1;31merr\033[0m %s\n' "$*" >&2; exit 1; }

[[ ${EUID:-$(id -u)} -ne 0 ]] || die "Run as your normal user (it'll sudo when needed), not root."

# Locate limine's config on the ESP.
conf=""
for c in /boot/limine.conf /boot/EFI/limine/limine.conf /boot/EFI/BOOT/limine.conf \
         /boot/limine.cfg /boot/EFI/limine/limine.cfg; do
  if sudo test -f "$c"; then conf="$c"; break; fi
done
[[ -n "$conf" ]] || die "No limine config found under /boot. This script only supports Limine."
log "Using limine config: $conf"

# --- Revert -------------------------------------------------------------------
if [[ "${1:-}" == "--revert" ]]; then
  bak="$(sudo bash -c 'ls -1t "'"$conf"'".rat.bak.* 2>/dev/null | head -1' || true)"
  [[ -n "$bak" ]] || die "No backup (${conf}.rat.bak.*) to revert to."
  sudo cp "$bak" "$conf"
  ok "Reverted $conf from $bak"
  exit 0
fi

# --- Apply --------------------------------------------------------------------
bak="${conf}.rat.bak.$(date +%Y%m%d-%H%M%S)"
sudo cp "$conf" "$bak"
log "Backed up to $bak"

tmp="$(mktemp)"
# Append $ADD to every kernel-cmdline line that doesn't already carry `quiet`.
# Handles modern `cmdline:` and legacy `KERNEL_CMDLINE=` syntaxes.
sudo awk -v add="$ADD" '
  (/^[[:space:]]*cmdline:/ || /KERNEL_CMDLINE=/) && $0 !~ /(^|[[:space:]])quiet([[:space:]]|$)/ {
    $0 = $0 " " add
  }
  { print }
' "$conf" > "$tmp"

if sudo cmp -s "$tmp" "$conf"; then
  ok "Already quiet — nothing to change."
  rm -f "$tmp"; exit 0
fi

sudo cp "$tmp" "$conf"; rm -f "$tmp"
ok "Updated kernel command line(s):"
sudo grep -nE '^[[:space:]]*cmdline:|KERNEL_CMDLINE=' "$conf" | sed 's/^/    /'

cat <<EOF

Done. Reboot to see the clean boot.
Errors and slow/hanging units will still appear automatically.
Undo any time with:  clean-boot --revert
EOF
