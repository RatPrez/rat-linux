#!/usr/bin/env bash
# install-joplin — build + install the Joplin desktop app from the AUR.
#
# Usage: install-joplin
set -euo pipefail

log() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
die() { printf '\033[1;31merr\033[0m %s\n' "$*" >&2; exit 1; }

[[ ${EUID:-$(id -u)} -ne 0 ]] || die "Run as your normal user, not root."
command -v yay >/dev/null || die "yay not found — run the main installer first."

log "Installing joplin-desktop from the AUR"
yay -S --needed joplin-desktop

log "Joplin installed."
